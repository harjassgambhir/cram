# ── Secrets ──────────────────────────────────────────────────────────────────
.env
.env.local
.env.*
!.env.example

# ── Python ───────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*.egg-info/
*.egg
.venv/
venv/
dist/
build/
*.so

# ── Runtime data (user-specific, never committed) ─────────────────────────────
~/.cram/
.cram/

# ── Generated outputs ────────────────────────────────────────────────────────
report_*.md
report_*.pdf
session_*/
*.research.txt
full-output-research.txt

# ── Claude Code internal ──────────────────────────────────────────────────────
.claude/

# ── Internal scratch files ────────────────────────────────────────────────────
my_opinions.txt
opus_*.md
sonnet_*.md
_private/

# ── IDE ───────────────────────────────────────────────────────────────────────
.DS_Store
.vscode/
.idea/
*.swp
*.swo

# ── Test coverage ─────────────────────────────────────────────────────────────
.coverage
htmlcov/
.pytest_cache/

# ── Jupyter ───────────────────────────────────────────────────────────────────
.ipynb_checkpoints/

# ── Lock files (keep uv.lock, ignore pip) ────────────────────────────────────
# uv.lock is intentionally committed for reproducibility

# eval: ignore ad-hoc run outputs, keep committed baseline_*.json artifacts
eval/results/recall_*.json
eval/results/planted_*.json
eval/results/full_pipeline.json
eval/results/*.log

# examples staging (per-run session data, not committed)
examples/_rundata/
