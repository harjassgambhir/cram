# CRAM-1 — Environment Variables
# Copy this file to .env and fill in your values.
# .env is loaded automatically at startup via python-dotenv.
# NEVER commit .env to version control.

# ── Required ──────────────────────────────────────────────────────────────────
OPENROUTER_API_KEY=sk-or-v1-...

# ── Model selection ───────────────────────────────────────────────────────────
# Default model (all phases if tier overrides not set)
OPENROUTER_MODEL=deepseek/deepseek-v4-flash

# Fallback model used when primary returns 429 (rate limit)
OPENROUTER_FALLBACK_MODEL=deepseek/deepseek-v4-flash

# ── Two-tier model architecture (recommended) ─────────────────────────────────
# Tier 1 — Big model: question analysis, BFS planning, synthesis, safety review
MODEL_BIG=deepseek/deepseek-v4-pro
# Tier 2 — Research model: DFS execution, verification, alerts, compaction
MODEL_RESEARCH=deepseek/deepseek-v4-flash

# Per-phase model overrides — all optional (override the tier defaults above).
# MODEL_SYNTHESIS=deepseek/deepseek-v4-pro
# MODEL_VERIFY=deepseek/deepseek-v4-flash
# MODEL_COMPACT=deepseek/deepseek-v4-flash
# MODEL_BFS=deepseek/deepseek-v4-pro
# MODEL_DFS=deepseek/deepseek-v4-flash
# MODEL_CONTRADICTION=deepseek/deepseek-v4-flash
# MODEL_SAFETY=deepseek/deepseek-v4-pro
# MODEL_ALERT=deepseek/deepseek-v4-flash     # Fast classifier — use cheapest
# MODEL_INTAKE=deepseek/deepseek-v4-pro
# MODEL_UU=deepseek/deepseek-v4-pro          # Unknown-unknowns pass

# ── Data storage ──────────────────────────────────────────────────────────────
# Where persistent memory, cache, and skill files live.
# Default: ~/.cram/
# CRAM_DATA_DIR=/path/to/persistent/storage

# ── Research parameters ───────────────────────────────────────────────────────
# CRAM_BFS_BRANCHES=6       # Number of parallel research branches
# CRAM_DFS_DEPTH=2          # Depth of follow-up search per branch
# CRAM_RESULTS_PER_SOURCE=10
# CRAM_MAX_WORKERS=6        # Parallel source fetches per branch
# CRAM_RATE_LIMIT_SLEEP=0.8

# ── Optional API keys ─────────────────────────────────────────────────────────

# NCBI API key — raises PubMed rate limit from 3 req/sec to 10/sec (free)
# Register at: ncbi.nlm.nih.gov/account/settings/
# NCBI_API_KEY=

# CORE API — 200M+ open-access papers (free key at core.ac.uk)
# CORE_API_KEY=

# Unpaywall — legal free full-text by DOI (free, email required)
UNPAYWALL_EMAIL=your-email@example.com

# Gemini — YouTube full-video clinical analysis (free tier at aistudio.google.com)
# GEMINI_API_KEY=
